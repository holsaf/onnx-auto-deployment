APP_ENV=dev
MODEL_URL=s3://your-bucket/models/resnet50.onnx
MODEL_PATH=models/resnet50.onnx
# Model downloaded during the test stage (can be the same as MODEL_URL).
TEST_MODEL=s3://your-bucket/models/resnet50.onnx
TEST_IMAGE_URL=s3://onnx-bucket-test/test-data/test_img.jpg
TEST_IMAGE_PATH=data/test/test_img.jpg
PREDICTION_LOG_PATH=predictions_dev.txt
PREDICTION_BUCKET=your-s3-bucket-name
PREDICTION_BUCKET_KEY=predictions/predictions_dev.txt
MIN_CONFIDENCE=0.80
# Optional. ImageNet class id(s) the test image must predict (comma-separated).
# 235 = German shepherd. Must match the class predicted for TEST_IMAGE_PATH/TEST_IMAGE_URL.
EXPECTED_CLASS_IDS=235
